    {
      "name": "API-007: Auth with Invalid Credentials",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"fake@invalid.com\",\"password\":\"wrongpassword\",\"returnSecureToken\":true}"
        },
        "url": {
          "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=AIzaSyDKBp0eUFt1mb2-XqCXa5td7gZ1zCAsM-s",
          "protocol": "https",
          "host": ["identitytoolkit", "googleapis", "com"],
          "path": ["v1", "accounts:signInWithPassword"],
          "query": [{"key": "key", "value": "AIzaSyDKBp0eUFt1mb2-XqCXa5td7gZ1zCAsM-s"}]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Returns 400 for invalid credentials', function () { pm.response.to.have.status(400); });",
            "pm.test('Response time < 2000ms', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
            "pm.test('Contains error message', function () { var j = pm.response.json(); pm.expect(j).to.have.property('error'); });"
          ]
        }
      }]
    }
