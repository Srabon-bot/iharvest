    {
      "name": "API-006: Invalid Endpoint Returns Error",
      "request": {
        "method": "GET",
        "url": {
          "raw": "https://firestore.googleapis.com/v1/projects/iharvest-platform/databases/(default)/documents/nonexistent_collection",
          "protocol": "https",
